## 4. FRONTEND TRACING

### Axios Interceptor with Trace ID

```typescript
// src/lib/axios-config.ts
import axios, { AxiosError, AxiosResponse } from 'axios';
import { v4 as uuidv4 } from 'uuid';

const TRACE_ID_HEADER = 'X-Trace-Id';
const TRACE_ID_STORAGE_KEY = 'app-trace-id';

// Generate or retrieve trace ID
function getOrCreateTraceId(): string {
  let traceId = sessionStorage.getItem(TRACE_ID_STORAGE_KEY);
  if (!traceId) {
    traceId = uuidv4().replace(/-/g, '').substring(0, 16);
    sessionStorage.setItem(TRACE_ID_STORAGE_KEY, traceId);
  }
  return traceId;
}

// Request interceptor - add trace ID
axios.interceptors.request.use(
  (config) => {
    const traceId = getOrCreateTraceId();
    config.headers[TRACE_ID_HEADER] = traceId;
    
    // Add to console for debugging
    console.debug(`[${traceId}] ${config.method?.toUpperCase()} ${config.url}`);
    
    return config;
  },
  (error) => {
    return Promise.reject(error);
  }
);

// Response interceptor - capture trace ID from response
axios.interceptors.response.use(
  (response: AxiosResponse) => {
    const traceId = response.headers[TRACE_ID_HEADER.toLowerCase()];
    if (traceId) {
      sessionStorage.setItem(TRACE_ID_STORAGE_KEY, traceId);
    }
    return response;
  },
  (error: AxiosError) => {
    const traceId = error.response?.headers[TRACE_ID_HEADER.toLowerCase()];
    if (traceId) {
      // Attach trace ID to error for logging
      (error as any).traceId = traceId;
    }
    return Promise.reject(error);
  }
);

export default axios;
```

### Enhanced Error Display with Trace ID

```typescript
// src/components/ErrorBoundary.tsx
'use client';

import { Component, ReactNode } from 'react';
import { AlertTriangle, Copy, Check } from 'lucide-react';
import { useState } from 'react';

interface Props {
  children: ReactNode;
}

interface State {
  hasError: boolean;
  error?: Error;
  traceId?: string;
}

export class ErrorBoundary extends Component<Props, State> {
  constructor(props: Props) {
    super(props);
    this.state = { hasError: false };
  }

  static getDerivedStateFromError(error: Error): State {
    const traceId = sessionStorage.getItem('app-trace-id') || 'unknown';
    return {
      hasError: true,
      error,
      traceId,
    };
  }

  componentDidCatch(error: Error, errorInfo: any) {
    const traceId = this.state.traceId;
    console.error(`[${traceId}] Error caught by boundary:`, error, errorInfo);
    
    // Send to monitoring service
    if (typeof window !== 'undefined') {
      fetch('/api/errors', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          traceId,
          error: error.message,
          stack: error.stack,
          componentStack: errorInfo.componentStack,
          timestamp: new Date().toISOString(),
        }),
      }).catch(console.error);
    }
  }

  render() {
    if (this.state.hasError) {
      return <ErrorDisplay error={this.state.error!} traceId={this.state.traceId!} />;
    }

    return this.props.children;
  }
}

function ErrorDisplay({ error, traceId }: { error: Error; traceId: string }) {
  const [copied, setCopied] = useState(false);

  const copyTraceId = () => {
