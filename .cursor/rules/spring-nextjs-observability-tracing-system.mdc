        span.setAttribute("user.id", id);
        span.setAttribute("service", "user-service");
        
        log.info("Fetching user: userId={}, traceId={}", id, TraceIdContext.getCurrentTraceId());
        
        AuthUser user = userRepository.findByIdAndDeletedFalse(id)
                .orElseThrow(() -> {
                    span.addEvent("User not found");
                    span.setStatus(StatusCode.ERROR, "User not found");
                    return new ResourceNotFoundException(ErrorCode.USER_NOT_FOUND);
                });
        
        span.addEvent("User found successfully");
        return toUserResponse(user);
    }
}
