### Enhanced GlobalExceptionHandler with Structured Logging

```java
@Slf4j
@RestControllerAdvice
@RequiredArgsConstructor
public class GlobalExceptionHandler {

    private final MessageService messageService;
    
    @ExceptionHandler(BusinessException.class)
    public ResponseEntity<ApiError> handleBusiness(BusinessException ex,
                                                    HttpServletRequest request) {
        String traceId = TraceIdContext.getCurrentTraceId();
        String path = request.getRequestURI();
        String method = request.getMethod();
        
        // Structured logging with all context
        log.warn("Business exception occurred: traceId={}, errorCode={}, path={}, method={}, userId={}, locale={}", 
            traceId, 
            ex.getErrorCode() != null ? ex.getErrorCode().getCode() : "UNKNOWN",
            path,
            method,
            SecurityContextHolder.getContext().getAuthentication() != null 
                ? SecurityContextHolder.getContext().getAuthentication().getName() 
                : "anonymous",
            LocaleContextHolder.getLocale()
        );
        
        String translatedMessage = ex.getErrorCode() != null 
            ? messageService.getMessage(ex.getErrorCode())
            : ex.getMessage();
        
        ApiError error = ApiError.builder()
                .code(ex.getErrorCode() != null ? ex.getErrorCode().getCode() : "UNKNOWN")
                .message(translatedMessage)
                .traceId(traceId)
                .path(path)
                .timestamp(Instant.now())
                .build();
                
        return ResponseEntity.status(ex.getStatus()).body(error);
    }
    
    @ExceptionHandler(Exception.class)
    public ResponseEntity<ApiError> handleGeneric(Exception ex,
                                                   HttpServletRequest request) {
        String traceId = TraceIdContext.getCurrentTraceId();
        String path = request.getRequestURI();
        
        // Critical error with full stack trace
        log.error("Unexpected error occurred: traceId={}, path={}, errorType={}", 
            traceId, path, ex.getClass().getName(), ex);
        
        String translatedMessage = messageService.getMessage(ErrorCode.SYSTEM_INTERNAL_ERROR);
        
        ApiError error = ApiError.builder()
                .code(ErrorCode.SYSTEM_INTERNAL_ERROR.getCode())
                .message(translatedMessage)
                .traceId(traceId)
                .path(path)
                .timestamp(Instant.now())
                .build();
                
        return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(error);
    }
}
