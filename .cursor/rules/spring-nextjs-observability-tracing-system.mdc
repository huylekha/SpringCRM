@Service
@RequiredArgsConstructor
public class UserService {
    
    private final UserRepository userRepository;
    private final MeterRegistry meterRegistry;
    
    @Timed(value = "user.service.getUser", description = "Time to get user by ID")
    public UserResponse getUser(String id) {
        Counter.builder("user.service.getUser.calls")
            .tag("method", "getUser")
            .register(meterRegistry)
            .increment();
        
        try {
            AuthUser user = userRepository.findByIdAndDeletedFalse(id)
                    .orElseThrow(() -> {
                        Counter.builder("user.service.getUser.notfound")
                            .register(meterRegistry)
                            .increment();
                        return new ResourceNotFoundException(ErrorCode.USER_NOT_FOUND);
                    });
            
            return toUserResponse(user);
        } catch (Exception e) {
            Counter.builder("user.service.getUser.errors")
                .tag("error", e.getClass().getSimpleName())
                .register(meterRegistry)
                .increment();
            throw e;
        }
    }
}
