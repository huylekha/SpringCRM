# EditorConfig - IDE Configuration
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
indent_size = 2
max_line_length = 120

[*.{xml,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.sh]
end_of_line = lf
indent_size = 2

# Generated code - disable inspections
[{target/**,build/**,out/**,**/generated/**,**/generated-sources/**}]
generated_code = true
