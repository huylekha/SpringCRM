# Docker Image Configuration
IMAGE_TAG=latest
REGISTRY_URL=local

# JWT Configuration (Required for auth-service)
JWT_PRIVATE_KEY=replace_me
JWT_PUBLIC_KEY=replace_me

# NextAuth Configuration (Required for frontend)
NEXTAUTH_SECRET=replace_me

# Monitoring and Error Tracking
SENTRY_DSN=

# Optional: Kafka Configuration (for crm-service)
KAFKA_BOOTSTRAP_SERVERS=

# Database Configuration (defaults are set in docker-compose.yml)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=crm_platform
# DB_USER=crm_user
# DB_PASSWORD=crm_password

# Redis Configuration (defaults are set in docker-compose.yml)
# REDIS_HOST=redis
# REDIS_PORT=6379