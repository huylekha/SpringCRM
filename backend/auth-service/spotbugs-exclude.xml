<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude Lombok generated code -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Exclude test classes -->
    <Match>
        <Class name="~.*Test.*"/>
    </Match>
    
    <!-- Exclude generated QueryDSL classes -->
    <Match>
        <Class name="~.*Q[A-Z].*"/>
    </Match>
    
    <!-- Exclude Spring Boot auto-configuration -->
    <Match>
        <Class name="~.*Configuration"/>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
    
    <!-- Exclude Lombok @With methods string comparison -->
    <Match>
        <Bug pattern="ES_COMPARING_PARAMETER_STRING_WITH_EQ"/>
        <Method name="~with.*"/>
    </Match>
    
    <!-- Exclude Lombok @With methods reference comparison -->
    <Match>
        <Bug pattern="RC_REF_COMPARISON"/>
        <Method name="~with.*"/>
    </Match>
</FindBugsFilter>